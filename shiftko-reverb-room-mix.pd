#N canvas 0 0 520 220 10;
#X obj 20 40 r reverb-room-base;
#X obj 20 70 float;
#X obj 20 100 r reverb-room-mul-lfo;
#X obj 20 130 float 1;
#X obj 240 40 r reverb-room-mul-rnd;
#X obj 240 70 float 1;
#X obj 240 110 expr $f1 * (($f2 <= 0) * 1 + ($f2 > 0) * $f2) * (($f3 <= 0) * 1 + ($f3 > 0) * $f3);
#X obj 240 150 s reverb-room;
#X obj 400 40 loadbang;
#X msg 400 70 \; reverb-room-mul-lfo 1 \; reverb-room-mul-rnd 1;
#X connect 0 0 1 0;
#X connect 1 0 6 0;
#X connect 2 0 3 0;
#X connect 3 0 6 1;
#X connect 4 0 5 0;
#X connect 5 0 6 2;
#X connect 6 0 7 0;
#X connect 8 0 9 0;
