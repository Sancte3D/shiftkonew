#N canvas 0 0 520 240 10;
#X text 20 200 cutoff = base * lfo * rnd * chaos | lfo/rnd 0.65-1.35 (ca. +-35% amp ~-3.7..+2.6 dB) chaos 0.72-1.28 (ca. +-28% ~-2.9..+2.1 dB);
#X obj 20 40 r filter-cutoff-base;
#X obj 20 70 float;
#X obj 20 100 r filter-cutoff-mul-lfo;
#X obj 20 130 float 1;
#X obj 20 160 r filter-cutoff-mul-rnd;
#X obj 20 190 float 1;
#X obj 240 40 r filter-cutoff-mul-chaos;
#X obj 240 70 float 1;
#X obj 240 110 expr $f1 * (($f2 <= 0) * 1 + ($f2 > 0) * $f2) * (($f3 <= 0) * 1 + ($f3 > 0) * $f3) * (($f4 <= 0) * 1 + ($f4 > 0) * $f4);
#X obj 240 150 s filter-cutoff;
#X obj 400 40 loadbang;
#X msg 400 70 \; filter-cutoff-mul-lfo 1 \; filter-cutoff-mul-rnd 1 \; filter-cutoff-mul-chaos 1;
#X connect 1 0 2 0;
#X connect 2 0 9 0;
#X connect 3 0 4 0;
#X connect 4 0 9 1;
#X connect 5 0 6 0;
#X connect 6 0 9 2;
#X connect 7 0 8 0;
#X connect 8 0 9 3;
#X connect 9 0 10 0;
#X connect 11 0 12 0;
